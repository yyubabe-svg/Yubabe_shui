    # 蜀水智库 AI 环境变量配置

# 数据库
DATABASE_URL=sqlite:///./shushui_ai.db

# 文件存储
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# 向量数据库
VECTOR_DB_PATH=./vector_db

# Embedding 配置
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# OpenAI 配置（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 火山方舟配置（可选）
VOLCANO_API_KEY=
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# LLM 配置
LLM_PROVIDER=mock
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Mock 模式（无 API Key 时启用）
MOCK_MODE=true

# 安全
SECRET_KEY=shushui-ai-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Chunk 配置
CHUNK_SIZE=500
CHUNK_OVERLAP=100
